{
  "name": "@zeitgeistpm/sdk",
  "version": "2.0.33",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/cjs/index.js",
  "types": "./dist/esm/index.d.ts",
  "scripts": {
    "build": "yarn compile",
    "compile": "rm -rf ./dist && rollup -c"
  },
  "peerDependencies": {
    "@polkadot/api": "*",
    "@polkadot/types": "*",
    "@polkadot/util": "*"
  },
  "dependencies": {
    "@zeitgeistpm/augment-api": "^2.0.23",
    "@zeitgeistpm/indexer": "^2.0.24",
    "@zeitgeistpm/rpc": "^2.0.23",
    "@zeitgeistpm/utility": "^2.0.25",
    "@zeitgeistpm/web3.storage": "^2.0.31",
    "bignumber.js": "^9.1.0",
    "cids": "^1.1.9",
    "lodash.memoize": "^4.1.2",
    "ms": "^2.1.3",
    "polly-js": "^1.8.3",
    "rxjs": "7.5.6",
    "superstruct": "^0.16.0"
  },
  "devDependencies": {
    "@types/lodash.memoize": "^4.1.7",
    "@types/ms": "^0.7.31"
  },
  "type": "module",
  "exports": {
    "./cjs/*": "./dist/cjs/*.js",
    ".": {
      "types": "./dist/esm/index.d.ts",
      "require": "./dist/cjs/index.js",
      "import": "./dist/esm/index.js"
    }
  }
}
