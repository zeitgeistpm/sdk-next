    "@polkadot/api": "*",
    "@polkadot/types": "*"
  },
  "dependencies": {
    "bignumber.js": "^9.1.0",
    "lodash.omit": "^4.5.0",
    "rxjs": "^7.2.0"
  },
  "devDependencies": {
    "@types/lodash.omit": "^4.5.7"
  }
}
