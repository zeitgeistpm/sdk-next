{
  "name": "@zeitgeistpm/utility",
  "version": "2.0.21",
  "publishConfig": {
    "access": "public"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "yarn compile && yarn generate-exports",
    "compile": "rimraf ./dist && rollup -c",
    "generate-exports": "node ./scripts/generate_exports.mjs",
    "test": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "@polkadot/api": "*",
    "@polkadot/types": "*"
  },
  "dependencies": {
    "bignumber.js": "^9.1.0",
    "lodash.omit": "^4.5.0",
    "rxjs": "^7.2.0"
  },
  "devDependencies": {
    "@types/lodash.omit": "^4.5.7"
  },
  "type": "module",
  "exports": {
    "./": "./dist/cjs/",
    "./aeither": {
