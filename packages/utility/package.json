{
  "name": "@zeitgeistpm/utility",
  "version": "2.0.21",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "yarn compile && yarn generate-exports",
